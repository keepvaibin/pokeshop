# Sonnet-py bot environment variables
# Copy this file to .env and fill in the values.
# The real .env is gitignored - never commit it.

# Discord bot token (sonnet-py reads SONNET_TOKEN natively)
SONNET_TOKEN=replace-with-discord-bot-token

# Django backend base URL (no trailing slash)
DJANGO_API_BASE_URL=https://api.santacruztcg.com

# Shared secret between bot and Django - must match SCTCG_BOT_API_KEY in backend .env
SCTCG_BOT_API_KEY=replace-with-generated-bot-api-key

# Comma-separated Discord guild IDs for slash command sync (leave blank for global)
DISCORD_GUILD_IDS=

# Discord support channel category ID (for /ticket command - right-click category -> Copy ID)
SUPPORT_CATEGORY_ID=

# Internal DM gateway - aiohttp server that Django POSTs to
BOT_INTERNAL_API_HOST=127.0.0.1
BOT_INTERNAL_API_PORT=8001

# --- Monitoring ---
# Your Discord user ID (right-click your name -> Copy User ID, requires Developer Mode)
# Leave blank to disable developer DM alerts
DEVELOPER_DISCORD_ID=